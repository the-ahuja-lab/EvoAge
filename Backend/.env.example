# -----------------------------------------
# UVICORN CONFIGURATION
# -----------------------------------------
UVICORN_HOST=localhost
UVICORN_PORT=1026
UVICORN_WORKERS=2
UVICORN_RELOAD_ON_CHANGE=True

# -----------------------------------------
# NEO4J DATABASE CONFIGURATION
# -----------------------------------------
NEO4J_URI=neo4j://SERVER_IP:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=YOUR_NEO4J_PASSWORD

# -----------------------------------------
# REDIS CONFIGURATION
# -----------------------------------------
REDIS_HOST=SERVER_IP
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# -----------------------------------------
# FRONTEND CONFIG
# -----------------------------------------
FRONTEND_URL=http://YOUR_FRONTEND_URL:8501

# -----------------------------------------
# JWT CONFIGURATION
# -----------------------------------------
JWT_SECRET_KEY=YOUR_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# -----------------------------------------
# EMAIL / SMTP CONFIGURATION
# -----------------------------------------
MAIL_USERNAME=YOUR_EMAIL
MAIL_PASSWORD=YOUR_EMAIL_APP_PASSWORD
MAIL_FROM=YOUR_EMAIL
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME="Your Name or Application Name"
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
MAIL_USE_CREDENTIALS=True
MAIL_VALIDATE_CERTS=True
MAIL_ADMIN_EMAIL=ADMIN_EMAIL

# -----------------------------------------
# DGL / DGL-KE CONFIGURATION
# -----------------------------------------
# Root directory for DGL-EvoKG files.
# Example (replace with your actual backend path):
#   ROOT_DIR_PATH=/storage/Arushi/EvoAge-backend/DGL-EvoKG
ROOT_DIR_PATH=/absolute/path/to/DGL-EvoKG

# Note:
# You may use ROOT_DIR_PATH (recommended) or provide full absolute paths.

# Node mappings file (filename may differ depending on your KG)
NODE_MAPPINGS_PATH=${ROOT_DIR_PATH}/Node_Mapping/node_id_HYCDZM_SPECIES_KG_all.pkl

# Trained DGL-KE model directory
MODEL_PATH=${ROOT_DIR_PATH}/Model/RotatE_wikimedia_128HidDim_emb/

# Entity and relation dictionaries (names may vary)
ENT_DICT_PATH=${ROOT_DIR_PATH}/Model/entities_FullEvoKG_Updated.dict
REL_DICT_PATH=${ROOT_DIR_PATH}/Model/relation_FullEvoKG.dict

# DGL-KE input directory and dummy lists
# NOTE:
# We have provided the dummy head and relation lists that were generated
# during our own model training. These dummy files are used ONLY for:
#   → Pre-loading the DGL-KE model onto the GPU for Link Prediction.
#
# Hypothesis Testing does NOT use these dummy files and does NOT
# require pre-loading the model.
DGLKE_INPUT_DIR=${ROOT_DIR_PATH}/Input
DGLKE_DUMMY_HEAD_LIST=${ROOT_DIR_PATH}/Dummy_Input/head.list
DGLKE_DUMMY_REL_LIST=${ROOT_DIR_PATH}/Dummy_Input/rel.list


# Optional configs
DGLKE_DEVICE=0
DGLKE_SFUNC=logsigmoid

# -----------------------------------------
# HYPOTHESIS TESTING CONFIGURATION
# -----------------------------------------
# Directory for hypothesis testing inputs
INPUT_DIR_HYPOTHESIS=${ROOT_DIR_PATH}/HypothesisTesting/InputHypothesis

API_BASE=http://SERVER_IP:1026
DEFAULT_ENTITY_PROP=id

# Cutoff summary file
# NOTE:
#   - We have provided a default file: "relation_cutoff_summary.csv".
#   - You may use this file OR replace it with your own cutoff file
CUTOFF_FILE_NAME=${ROOT_DIR_PATH}/HypothesisTesting/Cutoff/relation_cutoff_summary.csv

# Entity dictionary for hypothesis testing (filename may differ)
HYPOTHESIS_ENT_DICT_PATH=${ROOT_DIR_PATH}/HypothesisTesting/Model/entities_FullEvoKG_fixed_space.dict

# -----------------------------------------
# GEMINI / GOOGLE GENAI CONFIGURATION
# -----------------------------------------

# Provide a single API key or comma-separated multiple keys
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Model selection (default recommended)
GEMINI_MODEL=gemini-2.5-flash-lite